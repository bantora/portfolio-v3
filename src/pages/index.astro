---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Portfolio - The Free Encyclopedia of Projects</title>
	</head>
	<body class="bg-white text-[#202122] font-sans selection:bg-[#a7d7f9]">
		<div class="min-h-screen flex flex-col items-center justify-center p-4">
			
			<!-- Central Logo and Links Container -->
			<div class="relative w-full max-w-4xl flex flex-col items-center">
				
				<!-- Logo -->
				<div class="mb-8 relative group">
					<div class="w-40 h-40 md:w-48 md:h-48 bg-[#f8f9fa] border border-gray-200 rounded-full flex flex-col items-center justify-center shadow-sm relative z-10">
						<span class="text-6xl md:text-7xl font-serif">W</span>
						<span class="text-[10px] md:text-xs uppercase tracking-[0.2em] font-bold mt-1">Portfolio</span>
					</div>
					
					<!-- Circular Links (Desktop) -->
					<div class="hidden md:block absolute inset-0 -m-32 pointer-events-none">
						<!-- Battleship -->
						<div class="absolute top-1/2 left-0 -translate-y-1/2 pointer-events-auto text-right pr-48 w-1/2">
							<a href="/battleship" class="group">
								<strong class="block text-xl text-[#0645ad] group-hover:underline">Battleship PVP</strong>
								<span class="text-sm text-gray-500 italic">WebRTC Naval Combat</span>
							</a>
						</div>
						
						<!-- Beyblade -->
						<div class="absolute top-1/2 right-0 -translate-y-1/2 pointer-events-auto text-left pl-48 w-1/2">
							<a href="/beyblade-tracker" class="group">
								<strong class="block text-xl text-[#0645ad] group-hover:underline">Beyblade Tracker</strong>
								<span class="text-sm text-gray-500 italic">Tournament Management</span>
							</a>
						</div>

						<!-- Future Projects Placeholders -->
						<div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-auto text-center pb-48 h-1/2 flex flex-col justify-end">
							<div class="opacity-30 cursor-not-allowed">
								<strong class="block text-lg text-gray-400">Next Project</strong>
								<span class="text-xs text-gray-400 italic">Coming Soon</span>
							</div>
						</div>
						
						<div class="absolute bottom-0 left-1/2 -translate-x-1/2 pointer-events-auto text-center pt-48 h-1/2">
							<div class="opacity-30 cursor-not-allowed">
								<strong class="block text-lg text-gray-400">Experimental</strong>
								<span class="text-xs text-gray-400 italic">Under Construction</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Mobile Links (Simple list) -->
				<div class="md:hidden grid grid-cols-2 gap-8 mb-12 text-center">
					<a href="/battleship" class="group">
						<strong class="block text-[#0645ad] group-hover:underline">Battleship</strong>
						<span class="text-xs text-gray-500">WebRTC</span>
					</a>
					<a href="/beyblade-tracker" class="group">
						<strong class="block text-[#0645ad] group-hover:underline">Beyblade</strong>
						<span class="text-xs text-gray-500">Tracker</span>
					</a>
				</div>

				<!-- Search Bar Area -->
				<div class="w-full max-w-xl flex flex-col items-center">
					<div class="w-full flex border-2 border-[#a2a9b1] focus-within:border-[#3366cc] transition-colors rounded-sm overflow-hidden mb-4">
						<input 
							type="text" 
							placeholder="Search Projects..." 
							class="flex-1 px-4 py-2 outline-none text-lg"
						/>
						<button class="bg-[#3366cc] text-white px-6 py-2 font-bold hover:bg-[#2a4b8d] transition-colors">
							Search
						</button>
					</div>
					
					<div class="flex gap-4 text-sm text-[#0645ad]">
						<a href="#" class="hover:underline flex items-center gap-1">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6 6-6"/></svg>
							Read in your language
						</a>
					</div>
				</div>

			</div>

			<!-- Footer Links -->
			<footer class="mt-24 w-full max-w-5xl border-t border-gray-200 pt-8 flex flex-col items-center text-sm text-gray-600">
				<div class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-8 text-[#0645ad]">
					<a href="#" class="hover:underline flex items-center gap-2">
						<div class="w-4 h-4 bg-gray-200 rounded-sm"></div>
						Wiktionary
					</a>
					<a href="#" class="hover:underline flex items-center gap-2">
						<div class="w-4 h-4 bg-gray-200 rounded-sm"></div>
						Wikibooks
					</a>
					<a href="#" class="hover:underline flex items-center gap-2">
						<div class="w-4 h-4 bg-gray-200 rounded-sm"></div>
						Wikisource
					</a>
					<a href="#" class="hover:underline flex items-center gap-2">
						<div class="w-4 h-4 bg-gray-200 rounded-sm"></div>
						Wikivoyage
					</a>
				</div>
				
				<p class="text-center italic opacity-70">
					Portfolio is hosted by Ryan, the non-profit organization that also hosts a range of other projects.
				</p>
			</footer>
		</div>
	</body>
</html>

